# Anthropic API Key - required for --live mode
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# NVD API Key - optional, increases rate limit (get free key at https://nvd.nist.gov/developers/request-an-api-key)
NVD_API_KEY=your_nvd_api_key_here

# ChromaDB persistence path (default: ./chroma_db)
CHROMA_DB_PATH=./chroma_db

# LLM model to use (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Output directory
OUTPUT_DIR=./reports
