# Anthropic API Key (optional — demo mode works without it)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Demo mode - process sample_news_feed.json instead of live feed
DEMO_MODE=true

# Alert log file
ALERT_LOG=sentinel_alerts.log

# HuggingFace models (downloaded on first run, cached afterwards)
FINBERT_MODEL=ProsusAI/finbert
ZSC_MODEL=facebook/bart-large-mnli
SPACY_MODEL=en_core_web_sm
